# ─────────────────────────────────────────────────────────────────────────────
# RAG System — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=offrag
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/offrag

# ── Ollama (embeddings always; LLM only when LLM_BACKEND=ollama) ───────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_LLM_MODEL=phi3:mini              # lightweight model for M1 Macs
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=300

# ── LLM Backend: 'ollama' (local) or 'gemini' (cloud fallback) ────────────────
# Use 'gemini' when cloud infra is unavailable or on low-RAM machines.
# Ollama is still required for embeddings regardless of this setting.
LLM_BACKEND=gemini

# ── Gemini (free tier) ─────────────────────────────────────────────────────────
# Get your free API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# ── Reranker ──────────────────────────────────────────────────────────────────
# Set to false on M1 Macs with 8 GB RAM to save ~1 GB memory.
# Set to true if you have 16 GB+ RAM.
RERANKER_ENABLED=false

# ── Frontend / API URL ────────────────────────────────────────────────────────
# For local Docker: http://localhost:8000
# For Lightning AI: https://8000-01jxxxxxxxxxxxxxxxx.cloudspaces.litng.ai
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Multimodal Image Captioning (BLIP) ───────────────────────────────────────
# Set to true to extract and caption images from PDFs, PPTXs, and image uploads.
# Requires: pip install pdfplumber python-pptx Pillow transformers torch
# BLIP model is downloaded automatically on first ingestion run (~940 MB).
IMAGE_CAPTIONING_ENABLED=false

# BLIP model variant (lightest → heaviest):
#   Salesforce/blip-image-captioning-base   (~940 MB, ~1 GB RAM)  ← recommended
#   Salesforce/blip-image-captioning-large  (~1.9 GB, ~2.5 GB RAM)
#   Salesforce/blip2-opt-2.7b              (~6 GB, ~10 GB RAM — GPU recommended)
BLIP_MODEL=Salesforce/blip-image-captioning-base

# Minimum image dimensions to caption (px). Smaller images are skipped.
IMAGE_MIN_WIDTH_PX=80
IMAGE_MIN_HEIGHT_PX=80
